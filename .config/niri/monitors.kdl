output "HDMI-A-1" {
    mode "1920x1080@60"
    position x=-1920 y=0

    hot-corners {
        off
    }
}

output "HDMI-A-2" {
    mode "1920x1080@60"
    position x=0 y=0

    hot-corners {
        off
    }
}

output "DVI-D-1" {
    focus-at-startup
    mode "1920x1080@60"
    position x=1920 y=0

    hot-corners {
        off
    }
}
